# ==========================================
# LightBlog 环境变量配置
# 复制此文件为 .env 并修改实际值
# ==========================================

# 应用端口（默认 3000）
PORT=3000

# 生产环境设为 true（禁用 Express 静态文件，由 Nginx 提供）
DISABLE_STATIC=true

# 数据存储目录（默认 api/app-data）
# DATA_DIR=./app-data

# Session 密钥（生产环境务必修改为随机字符串）
# 留空则每次启动自动生成随机密钥（重启后所有用户需重新登录）
SESSION_SECRET=

# 管理员初始密码（仅首次创建用户时生效，留空自动生成）
# 首次启动后密码会打印在控制台，请立即修改
# ADMIN_PASSWORD=
# SUPERADMIN_PASSWORD=

# Node 环境（production 时 Cookie 仅通过 HTTPS 传输）
NODE_ENV=production